{
  "rewrites": [
    { "source": "/", "destination": "/velo-landing.html" },
    { "source": "/dashboard", "destination": "/velo-dashboard.html" },
    { "source": "/register", "destination": "/velo-register.html" },
    { "source": "/login", "destination": "/velo-auth.html" },
    { "source": "/settings", "destination": "/velo-settings.html" },
    { "source": "/history", "destination": "/velo-history.html" },
    { "source": "/reset", "destination": "/velo-reset.html" },
    { "source": "/admin", "destination": "/velo-admin.html" },
    { "source": "/partner", "destination": "/velo-partner.html" },
    { "source": "/partner/dashboard", "destination": "/velo-partner-dashboard.html" },
    { "source": "/payment", "destination": "/velo-payment.html" },
    { "source": "/bike/:serial", "destination": "/velo-bike.html?serial=:serial" },
    { "source": "/transfer", "destination": "/velo-transfer.html" },
    { "source": "/terms", "destination": "/velo-terms.html" },
    { "source": "/privacy", "destination": "/velo-privacy.html" }
  ]
}
